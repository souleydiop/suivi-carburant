{
  "id": "suivi-carburant-souleydiop-2026",
  "name": "Suivi Carburant",
  "short_name": "Carburant",
  "description": "Application de suivi carburant pour mon vehicule. Suivez vos depenses, consommation, entretiens et historique de pleins.",
  "start_url": "/suivi-carburant/index.html",
  "scope": "/suivi-carburant/",
  "display": "standalone",
  "display_override": ["tabbed", "window-controls-overlay", "standalone", "minimal-ui", "browser"],
  "orientation": "portrait",
  "background_color": "#080c09",
  "theme_color": "#e8a020",
  "lang": "fr",
  "dir": "ltr",
  "categories": ["utilities", "finance", "productivity"],
  "prefer_related_applications": false,
  "iarc_rating_id": "e84b072d-71b3-4d3e-86ae-31a8ce4e53b7",

  "scope_extensions": [
    { "origin": "https://souleydiop.github.io" }
  ],

  "file_handlers": [
    {
      "action": "/suivi-carburant/index.html",
      "accept": {
        "application/json": [".json"],
        "text/csv": [".csv"]
      },
      "icons": [{ "src": "icon-192.png", "sizes": "192x192", "type": "image/png" }],
      "launch_type": "single-client"
    }
  ],

  "launch_handler": {
    "client_mode": ["focus-existing", "auto"]
  },

  "protocol_handlers": [
    {
      "protocol": "web+carburant",
      "url": "/suivi-carburant/index.html?action=%s"
    }
  ],

  "share_target": {
    "action": "/suivi-carburant/index.html",
    "method": "GET",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },

  "edge_side_panel": {
    "preferred_width": 400
  },

  "note_taking": {
    "new_note_url": "/suivi-carburant/index.html#journal"
  },

  "handle_links": "preferred",

  "related_applications": [
    {
      "platform": "webapp",
      "url": "https://souleydiop.github.io/suivi-carburant/manifest.json",
      "id": "suivi-carburant-souleydiop-2026"
    }
  ],

  "shortcuts": [
